PORT=4000
# Public site URL used in email links. On production MUST be https://tarajuvva.com
# (localhost values are rewritten to https://tarajuvva.com in emails to avoid broken inbox links).
FRONTEND_URL=http://localhost:5173

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tarajuvva

# Optional: when local uploads/ is missing files that exist on production
# (common if MYSQL_HOST points at the shared remote DB). Local files still win.
# UPLOADS_FALLBACK_ORIGIN=https://tarajuvva.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Razorpay (secret stays server-side only)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here

JWT_SECRET=your-jwt-secret
# Auth token lifetime (user + admin). Default 90d (~3 months).
JWT_EXPIRES_IN=90d

# SMTP (GoDaddy: authenticate with primary mailbox; send from alias)
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_USER=support@tarajuvva.com
# SMTP_PASS=your-mailbox-password
# SMTP_FROM=contact@tarajuvva.com
# SMTP_FROM_NAME=Tarajuvva
# SMTP_REPLY_TO=support@tarajuvva.com
# NOTIFY_EMAIL=support@tarajuvva.com